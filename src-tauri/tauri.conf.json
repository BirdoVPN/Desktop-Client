{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BirdoVPN",
  "version": "1.3.41",
  "identifier": "uk.birdo.vpn.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "BirdoVPN",
        "label": "main",
        "width": 380,
        "height": 640,
        "resizable": false,
        "fullscreen": false,
        "center": false,
        "decorations": false,
        "transparent": false,
        "minWidth": 380,
        "minHeight": 640,
        "maxWidth": 380,
        "maxHeight": 640,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; font-src 'self' data:; connect-src 'self' https://birdo.app https://*.birdo.app; img-src 'self' data:; object-src 'none'; base-uri 'self'; frame-src 'none'; form-action 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi", "dmg", "app", "deb", "appimage"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "resources": [
      "resources/*"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": null,
      "timestampUrl": null,
      "allowDowngrades": false,
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "displayLanguageSelector": false,
        "languages": ["English"]
      },
      "wix": null
    },
    "macOS": {
      "minimumSystemVersion": "12.0",
      "signingIdentity": null,
      "entitlements": "Entitlements.plist",
      "frameworks": []
    },
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0", "libayatana-appindicator3-1", "iptables", "iproute2"],
        "section": "net",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    },
    "publisher": "Birdo VPN",
    "copyright": "© 2026 Birdo VPN. All rights reserved.",
    "category": "Utility",
    "shortDescription": "Privacy-First VPN Client",
    "longDescription": "Birdo VPN - A lightweight, secure VPN client using WireGuard protocol. Fast, private, and anonymous."
  },
  "plugins": {
    "shell": {
      "open": "^https?://(birdo\\.app|[a-zA-Z0-9-]+\\.birdo\\.app)(/.*)?$"
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.birdo.app/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ3MjREQjkxNjE0Nzk1MUUKUldRZWxVZGhrZHNrUjVmLzE5NUwvd0s1Zi9QVHhnK1NsT200MS9zSkJnZFZiZFhIdjFGWWZsTDgK"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["birdo"]
      }
    }
  }
}
